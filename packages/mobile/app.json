{
  "expo": {
    "name": "Idea Fuel",
    "slug": "ideafuel-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "ideafuel",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#161513"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ideafuel.mobile",
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#161513"
      },
      "package": "com.ideafuel.mobile",
      "usesCleartextTraffic": true
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Idea Fuel needs your microphone to capture ideas by voice.",
          "speechRecognitionPermission": "Idea Fuel needs speech recognition to transcribe your spoken ideas."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiUrl": "http://10.0.0.30:3006",
      "googleWebClientId": "897374181299-cgmmlpl915mh08sr6i451l1hbqst8ira.apps.googleusercontent.com",
      "googleIosClientId": "897374181299-74sbbislgbdqrt7opacl3s06f7bn8cv4.apps.googleusercontent.com",
      "googleAndroidClientId": "",
      "googleExpoClientId": "897374181299-cgmmlpl915mh08sr6i451l1hbqst8ira.apps.googleusercontent.com",
      "eas": {
        "projectId": ""
      }
    }
  }
}
