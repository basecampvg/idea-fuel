{
  "expo": {
    "name": "Idea Fuel",
    "slug": "ideafuel-mobile",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "ideafuel",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ideafuel.mobile",
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "Idea Fuel needs speech recognition to transcribe your spoken ideas.",
        "NSMicrophoneUsageDescription": "Idea Fuel needs your microphone to capture ideas by voice.",
        "NSCameraUsageDescription": "Idea Fuel needs your camera to capture photos for your ideas.",
        "NSPhotoLibraryUsageDescription": "Idea Fuel needs access to your photo library to let you add images to your ideas."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A0A"
      },
      "package": "com.ideafuel.mobile",
      "usesCleartextTraffic": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Idea Fuel needs your microphone to capture ideas by voice.",
          "speechRecognitionPermission": "Idea Fuel needs speech recognition to transcribe your spoken ideas."
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "Idea Fuel needs your camera to capture photos for your ideas.",
          "photosPermission": "Idea Fuel needs access to your photo library to add images to your ideas."
        }
      ],
      "./plugins/patch-turbomodule",
      [
        "expo-media-library",
        {
          "photosPermission": "Idea Fuel needs access to your photo library to save sketches.",
          "savePhotosPermission": "Idea Fuel needs permission to save sketches to your photo library."
        }
      ],
      "expo-web-browser",
      [
        "expo-build-properties",
        {
          "ios": {
            "buildReactNativeFromSource": true
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiUrl": "https://app.ideafuel.ai",
      "googleWebClientId": "117953471324-40im20410td9hoan1drsgj2sfpj797lu.apps.googleusercontent.com",
      "googleIosClientId": "117953471324-n6ufvodls46kvk9ekagd3jfoagbnn7aj.apps.googleusercontent.com",
      "googleAndroidClientId": "",
      "googleExpoClientId": "117953471324-40im20410td9hoan1drsgj2sfpj797lu.apps.googleusercontent.com",
      "revenueCatPublicIosKey": "appl_yzuLhHKhGMYnNKxMiJYfdPDDRXp",
      "revenueCatPublicAndroidKey": "",
      "eas": {
        "projectId": "04c6955c-0463-430f-ba65-5f1933a7f9e0"
      }
    },
    "owner": "basecampvg"
  }
}
