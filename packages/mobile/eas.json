{
  "cli": {
    "version": ">= 15.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "base": {
      "node": "20.18.0",
      "pnpm": {
        "version": "9.15.0"
      },
      "env": {
        "NPM_CONFIG_SHAMEFULLY_HOIST": "true",
        "NPM_CONFIG_NODE_LINKER": "hoisted"
      }
    },
    "development": {
      "extends": "base",
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": false
      }
    },
    "preview": {
      "extends": "base",
      "distribution": "internal",
      "autoIncrement": true
    },
    "testflight": {
      "extends": "base",
      "distribution": "store",
      "autoIncrement": true,
      "channel": "testflight"
    },
    "production": {
      "extends": "base",
      "distribution": "store",
      "autoIncrement": true,
      "channel": "production"
    }
  },
  "submit": {
    "testflight": {
      "ios": {
        "ascAppId": "6761184838"
      }
    },
    "production": {
      "ios": {
        "ascAppId": "6761184838"
      }
    }
  }
}
