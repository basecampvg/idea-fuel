{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TrendTriage",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "intent",
    "confidence",
    "pain_point",
    "purchase_proof",
    "news_spike_risk",
    "category",
    "evidence",
    "recommended_action"
  ],
  "properties": {
    "intent": {
      "type": "string",
      "enum": ["problem", "purchase", "mixed", "unclear"]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "pain_point": {
      "type": "object",
      "additionalProperties": false,
      "required": ["who", "problem_statement", "urgency"],
      "properties": {
        "who": { "type": "string", "minLength": 1 },
        "problem_statement": { "type": "string", "minLength": 1 },
        "urgency": { "type": "integer", "minimum": 1, "maximum": 5 }
      }
    },
    "purchase_proof": {
      "type": "object",
      "additionalProperties": false,
      "required": ["is_buying_intent", "buy_stage", "evidence"],
      "properties": {
        "is_buying_intent": { "type": "boolean" },
        "buy_stage": {
          "type": "string",
          "enum": ["researching", "comparing", "ready_to_buy", "unknown"]
        },
        "evidence": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 0
        }
      }
    },
    "news_spike_risk": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "category": { "type": "string", "minLength": 1 },
    "evidence": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "recommended_action": {
      "type": "string",
      "enum": ["ignore", "spark", "light", "forge"]
    }
  }
}
