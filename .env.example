# ==============================================
# Forge Automation - Environment Variables
# ==============================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control

# ==============================================
# Database (Supabase PostgreSQL)
# ==============================================
# Get these from your Supabase project settings > Database
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# ==============================================
# Auth.js Configuration
# ==============================================
# Generate a random secret: openssl rand -base64 32
AUTH_SECRET="your-auth-secret-at-least-32-characters-long"
AUTH_URL="http://localhost:3000"

# Google OAuth (required for web)
# Get these from Google Cloud Console > APIs & Services > Credentials
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Google OAuth for Mobile (required for Expo mobile app)
# Create separate OAuth 2.0 credentials for each platform in Google Cloud Console:
# - Web: Use for Expo Go development (type: Web application)
# - iOS: Create iOS client (type: iOS, bundle ID: com.forge.mobile)
# - Android: Create Android client (type: Android, package: com.forge.mobile)
# Then add these to packages/mobile/app.json under expo.extra
GOOGLE_WEB_CLIENT_ID="your-web-client-id.apps.googleusercontent.com"
GOOGLE_IOS_CLIENT_ID="your-ios-client-id.apps.googleusercontent.com"
GOOGLE_ANDROID_CLIENT_ID="your-android-client-id.apps.googleusercontent.com"

# Apple OAuth (optional - required for iOS App Store)
# Get these from Apple Developer Console
# APPLE_CLIENT_ID="your-apple-client-id"
# APPLE_CLIENT_SECRET="your-apple-client-secret"

# Facebook OAuth (optional)
# Get these from Meta Developer Console
# FACEBOOK_CLIENT_ID="your-facebook-app-id"
# FACEBOOK_CLIENT_SECRET="your-facebook-app-secret"

# ==============================================
# AI Providers
# ==============================================
# OpenAI (primary - for interviews and deep research)
OPENAI_API_KEY="sk-..."
# Set to "true" when you have access to GPT-5.2's reasoning/text params
# Leave as "false" to use gpt-5.2 without the extended parameters
OPENAI_USE_GPT52_PARAMS="false"

# Anthropic Claude (for extraction, generation, and business plans)
# Get your API key from: https://console.anthropic.com/
# Used for:
# - Structured data extraction (Claude Sonnet)
# - Creative content generation (Claude Sonnet)
# - Business plan writing (Claude Opus)
ANTHROPIC_API_KEY="sk-ant-..."

# Perplexity (optional - alternative deep research engine)
# Get your API key from: https://www.perplexity.ai/settings/api
# Uses sonar-deep-research model for async deep research with citations
# Users can toggle between OpenAI and Perplexity on the dashboard
# If not set, Perplexity option will be disabled in the UI
PERPLEXITY_API_KEY=""

# ==============================================
# Deep Research Configuration (o3-deep-research)
# ==============================================
# Extended timeout for deep research (default: 600000ms = 10 minutes)
# Deep research can take 5-10 minutes due to comprehensive web search
DEEP_RESEARCH_TIMEOUT="600000"

# Model selection:
# - FREE tier: Uses o4-mini-deep-research-2025-06-26 (faster, cheaper)
# - PRO/ENTERPRISE tier: Uses o3-deep-research-2025-06-26 (comprehensive)
# Set to "true" to enable deep research pipeline
# Set to "false" to use legacy GPT-5.2 only pipeline
OPENAI_USE_DEEP_RESEARCH="true"

# ==============================================
# Research APIs
# ==============================================
# Brave Search (social proof scraping - recommended)
# Get your API key from: https://api.search.brave.com/
# Used for cost-effective Reddit, Twitter, Facebook social proof scraping
# Cost: ~$0.01/query vs OpenAI web_search ~$15/call (98% savings)
# Falls back to OpenAI web_search if not configured or quality is low
BRAVE_SEARCH_API_KEY="BSA-..."

# Tavily (web search for market research)
TAVILY_API_KEY="tvly-..."

# SerpAPI (Google Trends data for keyword research)
# Get your API key from: https://serpapi.com/
# Used for real-time search trend data, related queries, and regional interest
# Falls back to AI-generated estimates if not configured
SERPAPI_API_KEY="your-serpapi-key"
# SERPAPI_DAILY_LIMIT="100"          # Total daily SerpAPI calls allowed
# SERPAPI_PER_PIPELINE_CAP="8"       # Max SerpAPI calls per individual pipeline run

# Apify (Reddit scraping for community insights)
APIFY_API_TOKEN="apify_api_..."

# ==============================================
# Redis (Upstash - for BullMQ job queue)
# ==============================================
# Get these from Upstash Console
UPSTASH_REDIS_REST_URL="https://[YOUR-ENDPOINT].upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# Worker Scaling
# RESEARCH_WORKER_CONCURRENCY="3"    # Concurrent research pipelines (default: 3)
# SPARK_WORKER_CONCURRENCY="2"       # Concurrent Spark pipelines (default: 2)
# MAX_RESEARCH_JOBS_PER_USER="1"     # Max queued research jobs per user (default: 1)

# ==============================================
# File Storage (Vercel Blob or AWS S3)
# ==============================================
# Vercel Blob (recommended)
BLOB_READ_WRITE_TOKEN="vercel_blob_..."

# OR AWS S3
# AWS_ACCESS_KEY_ID="..."
# AWS_SECRET_ACCESS_KEY="..."
# AWS_REGION="us-east-1"
# AWS_S3_BUCKET="forge-automation"

# ==============================================
# Email (Resend)
# ==============================================
RESEND_API_KEY="re_..."
EMAIL_FROM="noreply@yourdomain.com"

# ==============================================
# Daily Pick Feature (Trend Discovery)
# ==============================================
# Geographic region for trend data (e.g., US, GB, DE)
DEFAULT_GEO="US"
# Timeframe for Google Trends data (e.g., 90d, 12m)
DEFAULT_TIMEFRAME="90d"
# Timezone for daily pick scheduling
TZ="America/Denver"
# Maximum query candidates to process per run
MAX_CANDIDATES=200
# Minimum candidates that must pass intent filter
MIN_FILTERED_CANDIDATES=25
# If true, fall back to top candidates when filter yields too few
FALLBACK_ALLOW_NON_MATCHING="true"
# Number of top candidates to use in fallback
FALLBACK_TOP_N=25
# Maximum candidates to enrich with trend/SERP data
MAX_ENRICH=50
# Cache duration for trend/SERP data (hours)
CACHE_TTL_HOURS=24
# Minimum tokens required for "best" query selection
MIN_QUERY_TOKENS_FOR_BEST=3
# Minimum combined score for winner selection
MIN_WINNER_SCORE=55

# ==============================================
# Application Settings
# ==============================================
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Mobile app settings (for Expo)
EXPO_PUBLIC_API_URL="http://localhost:3000"

# ==============================================
# Subdomain Configuration (Production)
# ==============================================
# Root domain for production deployment
NEXT_PUBLIC_ROOT_DOMAIN="ideationlab.ai"
# App subdomain (main application)
NEXT_PUBLIC_APP_SUBDOMAIN="app.ideationlab.ai"
# Admin subdomain (admin panel)
NEXT_PUBLIC_ADMIN_SUBDOMAIN="admin.ideationlab.ai"

# ==============================================
# Admin Security
# ==============================================
# Comma-separated list of IPs allowed to access admin subdomain
# Leave empty to disable IP whitelist (not recommended for production)
ADMIN_IP_WHITELIST=""

# ==============================================
# Email Capture (Beehiiv)
# ==============================================
# Get these from Beehiiv Dashboard > Settings > API
BEEHIIV_API_KEY=""
BEEHIIV_PUBLICATION_ID=""

# ==============================================
# Redis / BullMQ (Alternative to Upstash)
# ==============================================
# Standard Redis URL (for local development or self-hosted)
# If set, takes precedence over Upstash credentials
# REDIS_URL="redis://localhost:6379"

# ==============================================
# ERP Integration (QuickBooks / Xero)
# ==============================================
# 32-byte hex key for encrypting ERP OAuth tokens at rest (AES-256-GCM)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ERP_ENCRYPTION_KEY=""

# ==============================================
# Logging
# ==============================================
# Log level: debug, info, warn, error (default: info in prod, debug in dev)
LOG_LEVEL="info"
