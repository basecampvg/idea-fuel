{
  "name": "forge-automation",
  "version": "0.1.0",
  "private": true,
  "description": "AI-powered business automation platform",
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "dev:web": "pnpm --filter @forge/web dev",
    "dev:server": "pnpm --filter @forge/server dev",
    "build": "pnpm -r run build",
    "build:web": "pnpm --filter @forge/web build",
    "vercel-build": "pnpm build:web",
    "build:server": "pnpm --filter @forge/server build",
    "lint": "pnpm -r run lint",
    "type-check": "pnpm -r run type-check",
    "db:generate": "pnpm --filter @forge/server db:generate",
    "db:push": "pnpm --filter @forge/server db:push",
    "db:migrate": "pnpm --filter @forge/server db:migrate",
    "db:studio": "pnpm --filter @forge/server db:studio"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "dependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/react": "19.1.0",
    "eslint": "^9.39.2",
    "eslint-config-next": "^15.5.12",
    "eslint-plugin-react-hooks": "^5.2.0",
    "next": "^15.5.12",
    "tailwindcss": "^4.0.0",
    "typescript-eslint": "^8.55.0"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.1.0",
      "@types/react-dom": "19.1.0"
    }
  }
}
