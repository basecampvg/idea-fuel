// Prisma Schema for Forge Automation
// Database: PostgreSQL (via Supabase)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String           @id @default(cuid())
  email         String           @unique
  emailVerified DateTime?        // Required for Auth.js
  name          String?
  passwordHash  String?
  image         String?
  subscription  SubscriptionTier @default(FREE)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  ideas      Idea[]
  interviews Interview[]
  reports    Report[]
  accounts   Account[]
  sessions   Session[]
}

enum SubscriptionTier {
  FREE        // Basic reports only
  PRO         // Pro-level reports
  ENTERPRISE  // Full reports with all features
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Idea {
  id          String     @id @default(cuid())
  title       String
  description String     @db.Text
  status      IdeaStatus @default(CAPTURED)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  interviews Interview[]
  reports    Report[]
  research   Research?

  @@index([userId])
  @@index([status])
}

// Interview model - supports auto-save and resume
// Messages are saved after each exchange, allowing users to resume anytime
model Interview {
  id              String          @id @default(cuid())
  mode            InterviewMode   @default(LIGHT)
  status          InterviewStatus @default(IN_PROGRESS)
  currentTurn     Int             @default(0)
  maxTurns        Int             @default(5)
  messages        Json            // Store conversation history as JSON
  collectedData   Json?           // 31 data points with weights/sources
  confidenceScore Int             @default(0)
  summary         String?         @db.Text

  // Auto-save & Resume support
  lastActiveAt    DateTime        @default(now()) // Last user activity timestamp
  lastMessageAt   DateTime?       // When last message was sent
  resumeContext   String?         @db.Text // AI context for seamless resume
  isExpired       Boolean         @default(false) // Mark abandoned after timeout

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  ideaId String
  idea   Idea   @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([ideaId])
  @@index([userId])
  @@index([status])
  @@index([mode])
  @@index([lastActiveAt])
}

enum InterviewMode {
  SPARK     // Quick validation - demand signals, TAM, keywords, Reddit/FB discovery
  LIGHT     // Fewer turns, faster completion
  IN_DEPTH  // More turns, comprehensive data collection
}

// Spark job status - for quick validation pipeline
// Pipeline: QUEUED → RUNNING_KEYWORDS → RUNNING_PARALLEL (Call 2+3) → SYNTHESIZING → COMPLETE
enum SparkJobStatus {
  QUEUED
  RUNNING_KEYWORDS
  RUNNING_RESEARCH    // Legacy: single deep research call
  RUNNING_PARALLEL    // New: Both demand + TAM calls running in parallel
  SYNTHESIZING        // New: GPT-5.2 merging results
  ENRICHING           // Legacy: kept for backward compatibility
  COMPLETE
  PARTIAL_COMPLETE    // New: One call succeeded, one failed
  FAILED
}

// Research model - powered by o3-deep-research with web search
// Triggered after interview completion
// NEW 4-Phase Pipeline: QUEUED → DEEP_RESEARCH → SYNTHESIS → SOCIAL_RESEARCH → REPORT_GENERATION → COMPLETE
// Legacy phases (QUERY_GENERATION, DATA_COLLECTION) kept for backward compatibility
// Spark mode uses simplified 2-step pipeline: keywords → research
model Research {
  id                   String         @id @default(cuid())
  status               ResearchStatus @default(PENDING)
  currentPhase         ResearchPhase  @default(QUEUED)
  progress             Int            @default(0) // 0-100 percentage
  estimatedCompletion  DateTime?      // ETA for user display
  startedAt            DateTime?      // When research actually started
  completedAt          DateTime?      // When research finished

  // Phase-specific data (populated as each phase completes)
  generatedQueries     Json?          // Search queries generated in Phase 1
  rawData              Json?          // Raw data from APIs (Tavily, Apify, SerpAPI)
  rawDeepResearch      Json?          // Phase 1 output for resume: { rawReport, citations, sources, searchQueriesUsed }
  researchChunks       Json?          // Chunked research progress: { market?, competitors?, painpoints?, timing? }
  synthesizedInsights  Json?          // AI-synthesized insights from Phase 3

  // Final consolidated research data
  marketAnalysis       Json?
  competitors          Json?
  painPoints           Json?
  positioning          Json?
  whyNow               Json?          // Market timing data
  proofSignals         Json?          // Demand validation evidence
  keywords             Json?          // SEO/search data

  // Dashboard Scores (0-100, computed during SYNTHESIS phase)
  opportunityScore     Int?           // Market opportunity rating
  problemScore         Int?           // Problem severity/urgency rating
  feasibilityScore     Int?           // Technical/resource feasibility
  whyNowScore          Int?           // Market timing score

  // Score Justifications & Metadata (multi-pass validated scoring)
  scoreJustifications  Json?          // { opportunity, problem, feasibility, whyNow } with justification text
  scoreMetadata        Json?          // { passCount, maxDeviation, averageConfidence, flagged, flagReason }

  // Business Fit Metrics (computed during SYNTHESIS phase)
  revenuePotential     Json?          // { rating, estimate, confidence }
  executionDifficulty  Json?          // { rating, factors, soloFriendly }
  gtmClarity           Json?          // { rating, channels, confidence }
  founderFit           Json?          // { percentage, strengths, gaps }

  // Keyword Trend Data (from data collection)
  keywordTrends        Json?          // [{ keyword, volume, growth, trend[] }]

  // Value Ladder (from VALUE_LADDER report or synthesis)
  valueLadder          Json?          // [{ tier, name, price, features }]

  // Action Prompts (pre-generated during REPORT_GENERATION)
  actionPrompts        Json?          // [{ id, title, description, prompt, category }]

  // User Story (AI-generated narrative)
  userStory            Json?          // { scenario, protagonist, problem, solution, outcome }

  // Social Proof (from Reddit, Facebook, Twitter - MVP: AI-simulated)
  socialProof          Json?          // { posts[], summary, painPointsValidated[], demandSignals[] }

  // TAM/SAM/SOM Market Sizing (computed during SYNTHESIS phase)
  marketSizing         Json?          // { tam, sam, som, segments, assumptions, sources, methodology }

  // Tech Stack Recommendations (computed during REPORT_GENERATION phase)
  techStack            Json?          // { businessType, layers, estimatedMonthlyCost, summary }

  // Spark mode fields (quick validation - 2-step pipeline)
  sparkStatus          SparkJobStatus? // Job status for Spark pipeline
  sparkKeywords        Json?          // { phrases[], synonyms[], query_plan }
  sparkResult          Json?          // Full Spark validation output (verdict, TAM, reddit, fb_groups, etc.)
  sparkStartedAt       DateTime?      // When Spark job started
  sparkCompletedAt     DateTime?      // When Spark job completed
  sparkError           String?        @db.Text // Error message if Spark failed

  // Error tracking
  errorMessage         String?        @db.Text
  errorPhase           ResearchPhase?
  retryCount           Int            @default(0)

  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  ideaId String @unique
  idea   Idea   @relation(fields: [ideaId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([currentPhase])
}

// Research pipeline phases
// NEW 4-Phase Pipeline (5-10 min total with o3-deep-research):
// - DEEP_RESEARCH: o3-deep-research with web_search (0-40%)
// - SYNTHESIS: GPT-5.2 structure extraction (40-70%)
// - SOCIAL_RESEARCH: Domain-filtered social proof search (70-85%)
// - REPORT_GENERATION: GPT-5.2 creative generation (85-100%)
enum ResearchPhase {
  QUEUED              // Waiting to start
  // New 4-phase pipeline phases
  DEEP_RESEARCH       // o3-deep-research with web_search (~5-10 min)
  SYNTHESIS           // GPT-5.2 extracts structured data (~1 min)
  SOCIAL_RESEARCH     // Domain-filtered social proof search (~1 min)
  REPORT_GENERATION   // GPT-5.2 generates creative content (~1 min)
  COMPLETE            // All done
  // Legacy phases (kept for backward compatibility)
  QUERY_GENERATION    // [Deprecated] AI generates search queries
  DATA_COLLECTION     // [Deprecated] External API calls
}

// Report model - tiered reports based on subscription + interview mode
// Tier determination:
//   SPARK mode → BASIC tier only (any subscription) - quick validation
//   LIGHT mode + FREE subscription → BASIC tier
//   LIGHT mode + PRO/ENTERPRISE subscription → PRO tier
//   IN_DEPTH mode + FREE subscription → PRO tier
//   IN_DEPTH mode + PRO/ENTERPRISE subscription → FULL tier
model Report {
  id        String       @id @default(cuid())
  type      ReportType   // Which report (Business Plan, Positioning, etc.)
  tier      ReportTier   // What level of detail (BASIC, PRO, FULL)
  title     String
  content   String       @db.Text // Full report content (JSON or markdown)
  sections  Json         // Sections included based on tier
  version   Int          @default(1)
  status    ReportStatus @default(DRAFT)
  pdfUrl    String?      // URL to generated PDF
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  ideaId String
  idea   Idea   @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([ideaId])
  @@index([userId])
  @@index([type])
  @@index([tier])
  @@index([status])
}

enum IdeaStatus {
  CAPTURED
  INTERVIEWING
  RESEARCHING
  COMPLETE
}

enum InterviewStatus {
  IN_PROGRESS
  COMPLETE
  ABANDONED
}

enum ResearchStatus {
  PENDING
  IN_PROGRESS
  COMPLETE
  FAILED
}

// 10 Report Types - each can be generated at different tiers
enum ReportType {
  BUSINESS_PLAN        // Full business plan
  POSITIONING          // Brand positioning & messaging
  COMPETITIVE_ANALYSIS // SWOT, competitor profiles
  WHY_NOW              // Market timing analysis
  PROOF_SIGNALS        // Demand validation evidence
  KEYWORDS_SEO         // SEO keyword strategy
  CUSTOMER_PROFILE     // Detailed customer persona
  VALUE_EQUATION       // Value proposition breakdown
  VALUE_LADDER         // Product/service tier strategy
  GO_TO_MARKET         // Comprehensive GTM strategy
}

// Report tiers - determined by subscription + interview mode blend
enum ReportTier {
  BASIC // Core insights only (SPARK mode or FREE+LIGHT)
  PRO   // Enhanced analysis (PRO+LIGHT or FREE+IN_DEPTH)
  FULL  // Comprehensive with all features (PRO/ENTERPRISE+IN_DEPTH)
}

enum ReportStatus {
  DRAFT
  GENERATING
  COMPLETE
  FAILED
}

// =============================================================================
// ADMIN CONFIGURATION
// =============================================================================

// Admin configuration storage - allows runtime control of app settings
model AdminConfig {
  id          String     @id @default(cuid())
  key         String     @unique // e.g., "ai.interview.model"
  value       Json       // Flexible value storage
  type        ConfigType @default(STRING)
  category    String     // Grouping: "ai", "research", "interview", "limits", "features", "domains"
  label       String     // Display name for UI
  description String?    // Help text
  options     Json?      // For SELECT type: [{ value, label }]
  updatedAt   DateTime   @updatedAt
  updatedBy   String?    // User ID who made the change

  @@index([category])
}

enum ConfigType {
  STRING
  NUMBER
  BOOLEAN
  JSON
  SELECT // For dropdowns with predefined options
}

// Audit log for config changes - tracks who changed what and when
model ConfigAuditLog {
  id        String   @id @default(cuid())
  configKey String
  oldValue  Json?
  newValue  Json
  changedBy String
  changedAt DateTime @default(now())
  reason    String?

  @@index([configKey])
  @@index([changedAt])
}

// =============================================================================
// TOKEN USAGE TRACKING
// =============================================================================

// Track OpenAI API token usage for cost monitoring
model TokenUsage {
  id            String   @id @default(cuid())
  userId        String?  // Nullable for system/background calls
  ideaId        String?  // Nullable for non-idea-specific calls
  functionName  String   // e.g., "extractInsights", "generateOpeningQuestion"
  model         String   // e.g., "gpt-5.2", "o3-deep-research"
  inputTokens   Int
  outputTokens  Int
  totalTokens   Int
  cachedTokens  Int      @default(0) // Tokens read from prompt cache (billed at 50% discount)
  costEstimate  Float?   // Estimated cost in USD
  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([functionName])
  @@index([model])
  @@index([createdAt])
}
