// Prisma Schema for Forge Automation
// Database: PostgreSQL (via Supabase)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  passwordHash String?
  image        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  ideas      Idea[]
  interviews Interview[]
  documents  Document[]
  accounts   Account[]
  sessions   Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Idea {
  id          String     @id @default(cuid())
  title       String
  description String     @db.Text
  status      IdeaStatus @default(CAPTURED)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  interviews Interview[]
  documents  Document[]
  research   Research?

  @@index([userId])
  @@index([status])
}

model Interview {
  id              String          @id @default(cuid())
  mode            InterviewMode   @default(LIGHT)
  status          InterviewStatus @default(IN_PROGRESS)
  currentTurn     Int             @default(0)
  maxTurns        Int             @default(5)
  messages        Json            // Store conversation history as JSON
  collectedData   Json?           // 31 data points with weights/sources
  confidenceScore Int             @default(0)
  summary         String?         @db.Text
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  ideaId String
  idea   Idea   @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([ideaId])
  @@index([userId])
  @@index([status])
  @@index([mode])
}

enum InterviewMode {
  LIGHT     // Fewer turns, faster completion
  IN_DEPTH  // More turns, comprehensive data collection
}

model Research {
  id             String         @id @default(cuid())
  status         ResearchStatus @default(PENDING)
  marketAnalysis Json?
  competitors    Json?
  painPoints     Json?
  positioning    Json?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  ideaId String @unique
  idea   Idea   @relation(fields: [ideaId], references: [id], onDelete: Cascade)

  @@index([status])
}

model Document {
  id        String         @id @default(cuid())
  type      DocumentType
  title     String
  content   String         @db.Text
  version   Int            @default(1)
  status    DocumentStatus @default(DRAFT)
  fileUrl   String? // URL to stored PDF/export
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  ideaId String
  idea   Idea   @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([ideaId])
  @@index([userId])
  @@index([type])
  @@index([status])
}

enum IdeaStatus {
  CAPTURED
  INTERVIEWING
  RESEARCHING
  COMPLETE
}

enum InterviewStatus {
  IN_PROGRESS
  COMPLETE
  ABANDONED
}

enum ResearchStatus {
  PENDING
  IN_PROGRESS
  COMPLETE
  FAILED
}

enum DocumentType {
  BUSINESS_PLAN
  POSITIONING
  PAIN_POINTS
  MARKET_ANALYSIS
  COMPETITOR_ANALYSIS
  EXECUTIVE_SUMMARY
  WHY_NOW
  PROOF_SIGNALS
  KEYWORDS_SEO
  CUSTOMER_PROFILE
  VALUE_EQUATION
  VALUE_LADDER
  GO_TO_MARKET
}

enum DocumentStatus {
  DRAFT
  GENERATING
  COMPLETE
}
